+constexpr char kDokeRuntimeSchema[] = "doke_profile_runtime.v1";
 
 int MaybeRunDokeProbe(const base::CommandLine& command_line) {
   if (!command_line.HasSwitch(kDokeProbeSwitch)) {
@@ -122,6 +129,51 @@ int MaybeRunDokeProbe(const base::CommandLine& command_line) {
   return 0;
 }
 
+void MaybeLoadDokeRuntimeConfig(const base::CommandLine& command_line) {
+  if (!command_line.HasSwitch(kDokeRuntimeConfigSwitch)) {
+    return;
+  }
+
+  const base::FilePath config_path =
+      command_line.GetSwitchValuePath(kDokeRuntimeConfigSwitch);
+  if (config_path.empty()) {
+    std::fputs("Doke runtime config path is empty\n", stderr);
+    return;
+  }
+
+  std::string contents;
+  if (!base::ReadFileToString(config_path, &contents)) {
+    std::fprintf(stderr, "Doke runtime config could not be read: %s\n",
+                 config_path.AsUTF8Unsafe().c_str());
+    return;
+  }
+
+  std::optional<base::Value> parsed = base::JSONReader::Read(contents);
+  if (!parsed || !parsed->is_dict()) {
+    std::fprintf(stderr, "Doke runtime config is not a JSON object: %s\n",
+                 config_path.AsUTF8Unsafe().c_str());
+    return;
+  }
+
+  const base::Value::Dict& root = parsed->GetDict();
+  const std::string* schema = root.FindString("schema");
+  if (!schema || *schema != kDokeRuntimeSchema) {
+    std::fprintf(stderr, "Doke runtime config schema mismatch: %s\n",
+                 config_path.AsUTF8Unsafe().c_str());
+    return;
+  }
+
+  const std::string* profile_id = root.FindString("profile_id");
+  if (!profile_id || profile_id->empty()) {
+    std::fprintf(stderr, "Doke runtime config profile_id is empty: %s\n",
+                 config_path.AsUTF8Unsafe().c_str());
+    return;
+  }
+
+  std::fprintf(stderr, "Doke runtime config loaded for profile %s\n",
+               profile_id->c_str());
+}
+
 }  // namespace
 
 const base::CommandLine& GetInitialBrowserCommandLine() {
@@ -216,6 +268,8 @@ int ChromeMain(int argc, const char** argv) {
     return doke_probe_result;
   }
 
+  MaybeLoadDokeRuntimeConfig(*command_line);
