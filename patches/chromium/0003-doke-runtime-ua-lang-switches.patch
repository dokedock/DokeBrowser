Doke-Purpose: Apply Doke runtime user-agent and language values as native Chrome command-line switches.
Doke-Subsystem: chrome/app startup command-line handling.
Doke-Detection-Target: BrowserScan and deviceandbrowserinfo UA/language consistency checks.
Doke-Rollback: Remove this patch from patches/chromium/series and rebuild Chromium; DokeBrowser will continue using existing Agent/CDP fallback paths.

diff --git a/chrome/app/chrome_main.cc b/chrome/app/chrome_main.cc
--- a/chrome/app/chrome_main.cc
+++ b/chrome/app/chrome_main.cc
@@ -68,6 +68,24 @@ std::optional<base::CommandLine>& GetInitialCommandLineStorage() {
 constexpr char kDokeProbeSwitch[] = "doke-probe";
 constexpr char kDokeRuntimeConfigSwitch[] = "doke-runtime-config";
 constexpr char kDokeRuntimeSchema[] = "doke_profile_runtime.v1";
+constexpr char kDokeUserAgentSwitch[] = "user-agent";
+constexpr char kDokeLanguageSwitch[] = "lang";
+
+void AppendStringSwitchIfAbsent(base::CommandLine& command_line,
+                                const char* switch_name,
+                                const base::DictValue& dict,
+                                const char* key) {
+  if (command_line.HasSwitch(switch_name)) {
+    return;
+  }
+
+  const std::string* value = dict.FindString(key);
+  if (!value || value->empty()) {
+    return;
+  }
+
+  command_line.AppendSwitchASCII(switch_name, *value);
+}
 
 int MaybeRunDokeProbe(const base::CommandLine& command_line) {
   if (!command_line.HasSwitch(kDokeProbeSwitch)) {
@@ -86,7 +103,7 @@ int MaybeRunDokeProbe(const base::CommandLine& command_line) {
   return 0;
 }
 
-void MaybeLoadDokeRuntimeConfig(const base::CommandLine& command_line) {
+void MaybeLoadDokeRuntimeConfig(base::CommandLine& command_line) {
   if (!command_line.HasSwitch(kDokeRuntimeConfigSwitch)) {
     return;
   }
@@ -128,6 +145,12 @@ void MaybeLoadDokeRuntimeConfig(const base::CommandLine& command_line) {
     return;
   }
 
+  const base::DictValue* fingerprint = root.FindDict("fingerprint");
+  if (fingerprint) {
+    AppendStringSwitchIfAbsent(command_line, kDokeUserAgentSwitch, *fingerprint, "user_agent");
+    AppendStringSwitchIfAbsent(command_line, kDokeLanguageSwitch, *fingerprint, "language");
+  }
+
   std::fprintf(stderr, "Doke runtime config loaded for profile %s\n",
                profile_id->c_str());
 }
