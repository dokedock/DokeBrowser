 void AppendStringSwitchIfAbsent(base::CommandLine& command_line,
                                 const char* switch_name,
@@ -84,6 +94,82 @@ void AppendStringSwitchIfAbsent(base::CommandLine& command_line,
   command_line.AppendSwitchASCII(switch_name, *value);
 }
 
+void AppendDokeBoolSwitchIfAbsent(base::CommandLine& command_line,
+                                  const char* switch_name,
+                                  const base::DictValue& dict,
+                                  const char* key) {
+  if (command_line.HasSwitch(switch_name)) {
+    return;
+  }
+  std::optional<bool> value = dict.FindBool(key);
+  if (!value.has_value()) {
+    return;
+  }
+  command_line.AppendSwitchASCII(switch_name, value.value() ? "true" : "false");
+}
+
+void AppendJsonListSwitchIfAbsent(base::CommandLine& command_line,
+                                  const char* switch_name,
+                                  const base::DictValue& dict,
+                                  const char* key) {
+  if (command_line.HasSwitch(switch_name)) {
+    return;
+  }
+  const base::ListValue* values = dict.FindList(key);
+  if (!values || values->empty()) {
+    return;
+  }
+  std::string json;
+  if (!base::JSONWriter::Write(*values, &json) || json.empty()) {
+    return;
+  }
+  command_line.AppendSwitchASCII(switch_name, json);
+}
+
+void MaybeApplyDokeUaClientHints(base::CommandLine& command_line,
+                                 const base::DictValue& fingerprint) {
+  const base::DictValue* hints = fingerprint.FindDict(kDokeUaClientHintsKey);
+  if (!hints) {
+    return;
+  }
+
+  const base::ListValue* brands = hints->FindList("brands");
+  const base::ListValue* full_version_list =
+      hints->FindList("fullVersionList");
+  const std::string* platform = hints->FindString("platform");
+  const std::string* full_version = hints->FindString("fullVersion");
+
+  if (!brands || !full_version_list || !platform || !full_version) {
+    std::fprintf(stderr, "%s", "Doke UA-CH metadata is incomplete\n");
+    return;
+  }
+
+  std::fprintf(stderr,
+               "Doke UA-CH metadata loaded platform=%s fullVersion=%s "
+               "brands=%zu fullVersionList=%zu\n",
+               platform->c_str(), full_version->c_str(), brands->size(),
+               full_version_list->size());
+
+  AppendJsonListSwitchIfAbsent(command_line, kDokeUaChBrandsSwitch, *hints,
+                               "brands");
+  AppendJsonListSwitchIfAbsent(command_line, kDokeUaChFullVersionListSwitch,
+                               *hints, "fullVersionList");
+  AppendStringSwitchIfAbsent(command_line, kDokeUaChFullVersionSwitch, *hints,
+                             "fullVersion");
+  AppendStringSwitchIfAbsent(command_line, kDokeUaChPlatformSwitch, *hints,
+                             "platform");
+  AppendStringSwitchIfAbsent(command_line, kDokeUaChPlatformVersionSwitch,
+                             *hints, "platformVersion");
+  AppendStringSwitchIfAbsent(command_line, kDokeUaChArchitectureSwitch, *hints,
+                             "architecture");
+  AppendStringSwitchIfAbsent(command_line, kDokeUaChModelSwitch, *hints,
+                             "model");
+  AppendStringSwitchIfAbsent(command_line, kDokeUaChBitnessSwitch, *hints,
+                             "bitness");
+  AppendDokeBoolSwitchIfAbsent(command_line, kDokeUaChMobileSwitch, *hints,
+                               "mobile");
+}
