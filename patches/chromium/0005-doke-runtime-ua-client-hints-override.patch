+constexpr char kDokeRuntimeConfigSwitch[] = "doke-runtime-config";
+constexpr char kDokeRuntimeSchema[] = "doke_profile_runtime.v1";
+
+bool ReadDokeBrandList(const base::Value::Dict& hints,
+                       const char* key,
+                       blink::UserAgentBrandList* out) {
+  const base::Value::List* values = hints.FindList(key);
+  if (!values || values->empty()) {
+    return false;
+  }
+
+  blink::UserAgentBrandList brands;
+  for (const base::Value& value : *values) {
+    const base::Value::Dict* item = value.GetIfDict();
+    if (!item) {
+      return false;
+    }
+    const std::string* brand = item->FindString("brand");
+    const std::string* version = item->FindString("version");
+    if (!brand || brand->empty() || !version || version->empty()) {
+      return false;
+    }
+    brands.emplace_back(*brand, *version);
+  }
+
+  *out = std::move(brands);
+  return true;
+}
+
+std::optional<blink::UserAgentMetadata> GetDokeUserAgentMetadataOverride() {
+  base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(kDokeRuntimeConfigSwitch)) {
+    return std::nullopt;
+  }
+
+  const base::FilePath config_path =
+      command_line->GetSwitchValuePath(kDokeRuntimeConfigSwitch);
+  if (config_path.empty()) {
+    return std::nullopt;
+  }
+
+  std::string contents;
+  if (!base::ReadFileToString(config_path, &contents)) {
+    return std::nullopt;
+  }
+
+  std::optional<base::Value> parsed = base::JSONReader::Read(contents);
+  if (!parsed || !parsed->is_dict()) {
+    return std::nullopt;
+  }
+
+  const base::Value::Dict& root = parsed->GetDict();
+  const std::string* schema = root.FindString("schema");
+  if (!schema || *schema != kDokeRuntimeSchema) {
+    return std::nullopt;
+  }
+
+  const base::Value::Dict* fingerprint = root.FindDict("fingerprint");
+  if (!fingerprint) {
+    return std::nullopt;
+  }
+  const base::Value::Dict* hints = fingerprint->FindDict("ua_client_hints");
+  if (!hints) {
+    return std::nullopt;
+  }
+
+  blink::UserAgentMetadata metadata;
+  if (!ReadDokeBrandList(*hints, "brands", &metadata.brand_version_list) ||
+      !ReadDokeBrandList(*hints, "fullVersionList",
+                         &metadata.brand_full_version_list)) {
+    return std::nullopt;
+  }
+
+  const std::string* full_version = hints->FindString("fullVersion");
+  const std::string* platform = hints->FindString("platform");
+  if (!full_version || full_version->empty() || !platform || platform->empty()) {
+    return std::nullopt;
+  }
+
+  const std::string* platform_version = hints->FindString("platformVersion");
+  const std::string* architecture = hints->FindString("architecture");
+  const std::string* model = hints->FindString("model");
+  const std::string* bitness = hints->FindString("bitness");
+
+  metadata.full_version = *full_version;
+  metadata.platform = *platform;
+  metadata.platform_version = platform_version ? *platform_version : "";
+  metadata.architecture = architecture ? *architecture : "";
+  metadata.model = model ? *model : "";
+  metadata.bitness = bitness ? *bitness : "";
+  metadata.mobile = hints->FindBool("mobile").value_or(false);
+  metadata.form_factors = {
+      metadata.mobile ? blink::kMobileFormFactor : blink::kDesktopFormFactor};
+  return metadata;
+}
