+constexpr char kDokeUaChBrandsSwitch[] = "doke-ua-ch-brands";
+constexpr char kDokeUaChFullVersionListSwitch[] = "doke-ua-ch-full-version-list";
+constexpr char kDokeUaChFullVersionSwitch[] = "doke-ua-ch-full-version";
+constexpr char kDokeUaChPlatformSwitch[] = "doke-ua-ch-platform";
+constexpr char kDokeUaChPlatformVersionSwitch[] = "doke-ua-ch-platform-version";
+constexpr char kDokeUaChArchitectureSwitch[] = "doke-ua-ch-architecture";
+constexpr char kDokeUaChModelSwitch[] = "doke-ua-ch-model";
+constexpr char kDokeUaChBitnessSwitch[] = "doke-ua-ch-bitness";
+constexpr char kDokeUaChMobileSwitch[] = "doke-ua-ch-mobile";
+
+bool ReadDokeBrandListSwitch(const base::CommandLine& command_line,
+                             const char* switch_name,
+                             blink::UserAgentBrandList* out) {
+  if (!command_line.HasSwitch(switch_name)) {
+    return false;
+  }
+
+  std::optional<base::ListValue> parsed = base::JSONReader::ReadList(
+      command_line.GetSwitchValueASCII(switch_name), base::JSON_PARSE_RFC);
+  if (!parsed) {
+    return false;
+  }
+
+  blink::UserAgentBrandList brands;
+  for (const base::Value& value : *parsed) {
+    const base::DictValue* item = value.GetIfDict();
+    if (!item) {
+      return false;
+    }
+    const std::string* brand = item->FindString("brand");
+    const std::string* version = item->FindString("version");
+    if (!brand || brand->empty() || !version || version->empty()) {
+      return false;
+    }
+    brands.emplace_back(*brand, *version);
+  }
+
+  if (brands.empty()) {
+    return false;
+  }
+  *out = std::move(brands);
+  return true;
+}
+
+bool IsDokeBoolSwitchEnabled(const base::CommandLine& command_line,
+                             const char* switch_name) {
+  const std::string value = command_line.GetSwitchValueASCII(switch_name);
+  return value == "true" || value == "1" || value == "yes";
+}
+
+std::optional<blink::UserAgentMetadata> GetDokeUserAgentMetadataOverride() {
+  base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(kDokeUaChBrandsSwitch) ||
+      !command_line->HasSwitch(kDokeUaChFullVersionListSwitch)) {
+    return std::nullopt;
+  }
+
+  blink::UserAgentMetadata metadata;
+  if (!ReadDokeBrandListSwitch(*command_line, kDokeUaChBrandsSwitch,
+                               &metadata.brand_version_list) ||
+      !ReadDokeBrandListSwitch(*command_line, kDokeUaChFullVersionListSwitch,
+                               &metadata.brand_full_version_list)) {
+    return std::nullopt;
+  }
+
+  const std::string full_version =
+      command_line->GetSwitchValueASCII(kDokeUaChFullVersionSwitch);
+  const std::string platform =
+      command_line->GetSwitchValueASCII(kDokeUaChPlatformSwitch);
+  if (full_version.empty() || platform.empty()) {
+    return std::nullopt;
+  }
+
+  metadata.full_version = full_version;
+  metadata.platform = platform;
+  metadata.platform_version =
+      command_line->GetSwitchValueASCII(kDokeUaChPlatformVersionSwitch);
+  metadata.architecture =
+      command_line->GetSwitchValueASCII(kDokeUaChArchitectureSwitch);
+  metadata.model = command_line->GetSwitchValueASCII(kDokeUaChModelSwitch);
+  metadata.bitness = command_line->GetSwitchValueASCII(kDokeUaChBitnessSwitch);
+  metadata.mobile =
+      IsDokeBoolSwitchEnabled(*command_line, kDokeUaChMobileSwitch);
+  metadata.form_factors = {
+      metadata.mobile ? blink::kMobileFormFactor : blink::kDesktopFormFactor};
+  return metadata;
+}
