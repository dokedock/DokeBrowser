Doke-Purpose: Apply Doke runtime screen and device metric values as native Chrome command-line switches.
Doke-Subsystem: chrome/app startup command-line handling.
Doke-Detection-Target: BrowserScan, CreepJS, and deviceandbrowserinfo screen/device consistency checks.
Doke-Rollback: Remove this patch from patches/chromium/series and rebuild Chromium; DokeBrowser will continue using existing Agent/CDP fallback paths.

diff --git a/chrome/app/chrome_main.cc b/chrome/app/chrome_main.cc
--- a/chrome/app/chrome_main.cc
+++ b/chrome/app/chrome_main.cc
@@ -73,4 +73,7 @@ constexpr char kDokeUaChMobileSwitch[] = "doke-ua-ch-mobile";
 constexpr char kDokeWebRtcIpHandlingPolicySwitch[] = "force-webrtc-ip-handling-policy";
+constexpr char kDokeWindowSizeSwitch[] = "window-size";
+constexpr char kDokeDeviceScaleFactorSwitch[] = "force-device-scale-factor";
+constexpr char kDokeTouchEventsSwitch[] = "touch-events";
 
 void AppendStringSwitchIfAbsent(base::CommandLine& command_line,
                                 const char* switch_name,
@@ -169,5 +172,8 @@ void MaybeLoadDokeRuntimeConfig(base::CommandLine& command_line) {
   if (fingerprint) {
     AppendStringSwitchIfAbsent(command_line, kDokeUserAgentSwitch, *fingerprint, "user_agent");
     AppendStringSwitchIfAbsent(command_line, kDokeLanguageSwitch, *fingerprint, "language");
+    AppendStringSwitchIfAbsent(command_line, kDokeWindowSizeSwitch, *fingerprint, "window_size");
+    AppendStringSwitchIfAbsent(command_line, kDokeDeviceScaleFactorSwitch, *fingerprint, "device_scale_factor_arg");
+    AppendStringSwitchIfAbsent(command_line, kDokeTouchEventsSwitch, *fingerprint, "touch_events");
     MaybeApplyDokeUaClientHints(command_line, *fingerprint);
   }
