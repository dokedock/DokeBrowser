Doke-Purpose: Ingest Doke runtime rendering noise seeds for Canvas, WebGL, and Audio surfaces.
Doke-Subsystem: chrome/app startup command-line handling.
Doke-Detection-Target: CreepJS and FingerprintJS Canvas/WebGL/Audio consistency checks.
Doke-Rollback: Remove this patch from patches/chromium/series and rebuild Chromium; DokeBrowser will keep writing rendering seeds but Chromium will ignore them.

diff --git a/chrome/app/chrome_main.cc b/chrome/app/chrome_main.cc
--- a/chrome/app/chrome_main.cc
+++ b/chrome/app/chrome_main.cc
@@ -43,6 +43,9 @@ constexpr char kDokeDeviceScaleFactorSwitch[] = "force-device-scale-factor";
 constexpr char kDokeTouchEventsSwitch[] = "touch-events";
 constexpr char kDokeHardwareConcurrencySwitch[] = "doke-hardware-concurrency";
 constexpr char kDokeDeviceMemoryGbSwitch[] = "doke-device-memory-gb";
+constexpr char kDokeCanvasNoiseSeedSwitch[] = "doke-canvas-noise-seed";
+constexpr char kDokeWebglNoiseSeedSwitch[] = "doke-webgl-noise-seed";
+constexpr char kDokeAudioNoiseSeedSwitch[] = "doke-audio-noise-seed";
 
 void AppendStringSwitchIfAbsent(base::CommandLine& command_line,
                                 const char* switch_name,
@@ -141,7 +144,22 @@ void MaybeApplyDokeUaClientHints(base::CommandLine& command_line,
   AppendDokeBoolSwitchIfAbsent(command_line, kDokeUaChMobileSwitch, *hints,
                                "mobile");
 }
 
+void AppendRenderingNoiseSwitchIfAbsent(base::CommandLine& command_line,
+                                        const base::DictValue& rendering,
+                                        const char* section_name,
+                                        const char* switch_name) {
+  const base::DictValue* section = rendering.FindDict(section_name);
+  if (!section) {
+    return;
+  }
+  const std::string* strategy = section->FindString("strategy");
+  if (!strategy || *strategy != "stable_noise") {
+    return;
+  }
+  AppendStringSwitchIfAbsent(command_line, switch_name, *section, "seed");
+}
