+void AppendPlatformPresetSwitchIfAbsent(base::CommandLine& command_line,
+                                        const base::Value::Dict& surfaces,
+                                        const char* section_name,
+                                        const char* switch_name) {
+  const base::Value::Dict* section = surfaces.FindDict(section_name);
+  if (!section) {
+    return;
+  }
+  const std::string* strategy = section->FindString("strategy");
+  if (!strategy || *strategy != "platform_preset") {
+    return;
+  }
+  AppendStringSwitchIfAbsent(command_line, switch_name, *section, "preset");
+}
+
+void AppendSurfaceSeedSwitchIfAbsent(base::CommandLine& command_line,
+                                     const base::Value::Dict& surfaces,
+                                     const char* section_name,
+                                     const char* switch_name) {
+  const base::Value::Dict* section = surfaces.FindDict(section_name);
+  if (!section) {
+    return;
+  }
+  AppendStringSwitchIfAbsent(command_line, switch_name, *section, "seed");
+}
