+void AppendAlignmentSwitchesIfAbsent(base::CommandLine& command_line,
+                                     const base::DictValue& alignment) {
+  AppendStringSwitchIfAbsent(command_line, kDokeAlignmentLanguageSwitch, alignment, "language");
+  AppendStringSwitchIfAbsent(command_line, kDokeTimezoneIdSwitch, alignment, "timezone");
+
+  const base::DictValue* geo = alignment.FindDict("geo");
+  if (geo) {
+    AppendStringSwitchIfAbsent(command_line, kDokeGeoLatitudeSwitch, *geo, "latitude_arg");
+    AppendStringSwitchIfAbsent(command_line, kDokeGeoLongitudeSwitch, *geo, "longitude_arg");
+    AppendStringSwitchIfAbsent(command_line, kDokeGeoAccuracySwitch, *geo, "accuracy_arg");
+  }
+
+  const base::DictValue* proxy = alignment.FindDict("proxy");
+  if (proxy) {
+    AppendStringSwitchIfAbsent(command_line, kDokeProxySchemeSwitch, *proxy, "scheme");
+    AppendStringSwitchIfAbsent(command_line, kDokeProxyHostSwitch, *proxy, "host");
+    AppendStringSwitchIfAbsent(command_line, kDokeProxyPortSwitch, *proxy, "port_arg");
+  }
+}
