+constexpr char kDokeTimezoneIdSwitch[] = "doke-timezone-id";
+constexpr char kDokeGeoLatitudeSwitch[] = "doke-geo-latitude";
+constexpr char kDokeGeoLongitudeSwitch[] = "doke-geo-longitude";
+constexpr char kDokeGeoAccuracySwitch[] = "doke-geo-accuracy";
