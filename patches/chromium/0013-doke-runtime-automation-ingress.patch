+void AppendBoolSwitchIfAbsent(base::CommandLine& command_line,
+                              const char* switch_name,
+                              const base::DictValue& dict,
+                              const char* key) {
+  if (command_line.HasSwitch(switch_name)) {
+    return;
+  }
+  std::optional<bool> value = dict.FindBool(key);
+  if (!value.has_value()) {
+    return;
+  }
+  command_line.AppendSwitchASCII(switch_name, value.value() ? "true" : "false");
+}
+
+void AppendAutomationSwitchesIfAbsent(base::CommandLine& command_line,
+                                      const base::DictValue& automation) {
+  AppendStringSwitchIfAbsent(command_line, kDokeWebdriverPolicySwitch, automation, "webdriver_policy");
+  AppendStringSwitchIfAbsent(command_line, kDokeDevtoolsExposureSwitch, automation, "devtools_exposure");
+  AppendBoolSwitchIfAbsent(command_line, kDokeCdpSideEffectGuardSwitch, automation, "cdp_side_effect_guard");
+  AppendBoolSwitchIfAbsent(command_line, kDokeDebugPortRequiredSwitch, automation, "debug_port_required");
+  AppendBoolSwitchIfAbsent(command_line, kDokeStartupAutomationControlledSwitch, automation, "startup_automation_controlled");
+}
