Doke-Purpose: Apply Doke webdriver policy to Blink navigator.webdriver.
Doke-Subsystem: third_party/blink navigator automation surface.
Doke-Detection-Target: BrowserScan bot detection, CreepJS, deviceandbrowserinfo, and bot.incolumitas webdriver checks.
Doke-Rollback: Remove this patch from patches/chromium/series and rebuild Chromium; DokeBrowser will continue using Agent/CDP fallback for webdriver masking.

diff --git a/third_party/blink/renderer/core/frame/navigator.cc b/third_party/blink/renderer/core/frame/navigator.cc
--- a/third_party/blink/renderer/core/frame/navigator.cc
+++ b/third_party/blink/renderer/core/frame/navigator.cc
@@ -23,6 +23,9 @@
 
 #include "third_party/blink/renderer/core/frame/navigator.h"
 
+#include <optional>
+
+#include "base/command_line.h"
 #include "third_party/blink/renderer/bindings/core/v8/script_controller.h"
 #include "third_party/blink/renderer/core/dom/document.h"
 #include "third_party/blink/renderer/core/execution_context/navigator_base.h"
@@ -37,6 +40,28 @@
 
 namespace blink {
 
+namespace {
+
+constexpr char kDokeWebdriverPolicySwitch[] = "doke-webdriver-policy";
+
+std::optional<bool> GetDokeWebdriverOverride() {
+  const std::string value = base::CommandLine::ForCurrentProcess()
+                                ->GetSwitchValueASCII(kDokeWebdriverPolicySwitch);
+  if (value.empty()) {
+    return std::nullopt;
+  }
+  if (value == "hide" || value == "false" || value == "0") {
+    return false;
+  }
+  if (value == "show" || value == "true" || value == "1" ||
+      value == "automation") {
+    return true;
+  }
+  return std::nullopt;
+}
+
+}  // namespace
+
 Navigator::Navigator(ExecutionContext* context) : NavigatorBase(context) {}
 
 String Navigator::productSub() const {
@@ -97,6 +122,11 @@ bool Navigator::cookieEnabled() const {
 }
 
 bool Navigator::webdriver() const {
+  std::optional<bool> doke_webdriver = GetDokeWebdriverOverride();
+  if (doke_webdriver.has_value()) {
+    return doke_webdriver.value();
+  }
+
   if (RuntimeEnabledFeatures::AutomationControlledEnabled())
     return true;
 
